# Patch: Log tokens/sec/GPU to stdout, TensorBoard, and W&B
#
# Problem:
#   Megatron-LM logs throughput as TFLOP/s/GPU but does not log tokens/sec/GPU.
#   For an efficiency challenge where wall-clock token throughput matters,
#   tokens/sec/GPU is the more actionable metric. It is also not logged to
#   W&B or TensorBoard, making it hard to compare runs.
#
# What this patch does:
#   Adds a `tokens_per_sec_per_gpu` metric to the training log loop in
#   megatron/training/training.py, inside the `if args.log_throughput` block.
#   Specifically:
#     1. Computes tokens/sec/GPU = (global_batch_size * seq_length) / (elapsed_time * world_size)
#     2. Appends it to the stdout log string
#     3. Logs it to TensorBoard as 'tokens-per-sec-per-gpu'
#     4. Logs it to W&B as 'tokens-per-sec-per-gpu'
#
# Where in the code:
#   File: megatron/training/training.py
#   Function: training_log()
#   Location: inside the `if args.log_throughput:` block, right after the
#   existing `throughput` (TFLOP/s) computation and logging (~line 2043).
#
# How to fix if this patch breaks on a future Megatron version:
#   Search for `log_throughput` in training.py. Find the block that computes
#   `throughput = num_floating_point_operations(...)` and logs it to
#   writer/wandb_writer. Add the tokens_per_sec_per_gpu computation and
#   logging calls in the same block.
#
# Applied to: Megatron-LM core_v0.16.1
#
diff --git a/megatron/training/training.py b/megatron/training/training.py
index d61b9357a..a51a9846a 100644
--- a/megatron/training/training.py
+++ b/megatron/training/training.py
@@ -2041,12 +2041,18 @@ def training_log(
             elapsed_time_per_iteration * 1000.0
         )
         if args.log_throughput:
+            tokens_per_sec_per_gpu = batch_size * args.seq_length / (
+                elapsed_time_per_iteration * args.world_size
+            )
             log_string += f' throughput per GPU (TFLOP/s/GPU): {throughput:.1f} |'
+            log_string += f' tokens/sec/GPU: {tokens_per_sec_per_gpu:.0f} |'
             if args.log_timers_to_tensorboard:
                 if writer:
                     writer.add_scalar('throughput', throughput, iteration)
+                    writer.add_scalar('tokens-per-sec-per-gpu', tokens_per_sec_per_gpu, iteration)
                 if wandb_writer:
                     wandb_writer.log({'throughput': throughput}, iteration)
+                    wandb_writer.log({'tokens-per-sec-per-gpu': tokens_per_sec_per_gpu}, iteration)
         if args.log_energy:
             energy = (energy_monitor.lap() / total_iterations) / args.world_size
             power = energy / elapsed_time_per_iteration
